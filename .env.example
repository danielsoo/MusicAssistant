# Copy this file to .env and set your values
# Optional: comma-separated Demucs models (each runs a full separation — more = slower).
# DEMUCS_MODEL_NAMES=htdemucs_6s
# DEMUCS_MODEL_NAMES=htdemucs_6s,htdemucs_ft
# Chord learning (your manual saves are logged under data/; enable priors to nudge new analyses)
# CHORD_APPLY_LEARNED_PRIORS=1
# CHORD_PRIOR_MIN_COUNT=3
# CHORD_PRIOR_MIN_RATIO=0.45
# CHORD_PRIOR_CONF_CAP=0.82
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=music_assistant
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
